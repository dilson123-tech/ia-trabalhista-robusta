APP_NAME="IA Trabalhista Robusta"
APP_ENV="dev"
LOG_LEVEL="INFO"
API_V1_PREFIX="/api/v1"

AUTH_ENABLED="true"
AUTH_PROTECT_DOCS="false"

# DEV: use um segredo forte com pelo menos 32 caracteres.
# PROD/STAGING: obrigatório usar segredo real e exclusivo do ambiente.
JWT_SECRET="CHANGE_ME_DEV_ONLY_MIN_32_CHARS"
JWT_EXPIRES_MIN="60"

# Break-glass apenas para bootstrap controlado.
# Em produção, manter ALLOW_SEED_ADMIN=false por padrão.
ADMIN_SEED_TOKEN="CHANGE_ME_SEED_TOKEN"
ALLOW_SEED_ADMIN="false"

# DEV local (docker-compose)
DATABASE_URL="postgresql+psycopg2://ia_user:ia_pass@127.0.0.1:55432/ia_trabalhista"

# Lista separada por vírgula.
CORS_ALLOW_ORIGINS="http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://127.0.0.1:4173"

# IA
LLM_PROVIDER="openai"
LLM_API_KEY=""
LLM_MODEL="gpt-5-mini"
LLM_TIMEOUT_SECONDS="90"
LLM_ANALYSIS_ENABLED="false"
LLM_BASE_URL=""

# Regras de ambiente production-like:
# - AUTH_PROTECT_DOCS=true
# - DATABASE_URL não pode apontar para o default local
# - se ALLOW_SEED_ADMIN=true, ADMIN_SEED_TOKEN deve ser real
