from __future__ import annotations

import time
import uuid
from typing import Optional, Tuple

import anyio
from functools import partial
import jwt
from starlette.middleware.base import BaseHTTPMiddleware
from starlette.requests import Request
from starlette.types import ASGIApp

from app.core.settings import settings
from app.db.session import SessionLocal
from app.models.audit_log import AuditLog


def _jwt_secret_and_alg() -> Tuple[str, str]:
    # compat: nomes podem variar conforme settings evolui
    secret = getattr(settings, "JWT_SECRET", "") or getattr(settings, "AUTH_JWT_SECRET", "") or "CHANGE_ME_JWT_SECRET"
    alg = getattr(settings, "JWT_ALG", "") or getattr(settings, "AUTH_JWT_ALG", "") or "HS256"
    return secret, alg


def _extract_claims(auth_header: Optional[str]) -> Tuple[Optional[str], Optional[str]]:
    if not auth_header:
        return None, None
    parts = auth_header.split()
    if len(parts) != 2 or parts[0].lower() != "bearer":
        return None, None
    token = parts[1]
    secret, alg = _jwt_secret_and_alg()
    try:
        payload = jwt.decode(token, secret, algorithms=[alg])
        return payload.get("sub"), payload.get("role")
    except Exception:
        return None, None


def _write_audit_row(
    *,
    request_id: str,
    method: str,
    path: str,
    status_code: int,
    process_time_ms: float,
    username: Optional[str],
    role: Optional[str],
    client_ip: Optional[str],
    user_agent: Optional[str],
) -> None:
    db = SessionLocal()
    try:
        db.add(
            AuditLog(
                request_id=request_id,
                method=method,
                path=path,
                status_code=status_code,
                process_time_ms=float(process_time_ms),
                username=username,
                role=role,
                client_ip=client_ip,
                user_agent=user_agent,
            )
        )
        db.commit()
    except Exception as e:
        db.rollback()
        import sys, traceback
        print(f"AUDIT_WRITE_FAIL: {e!r}", file=sys.stderr)
        traceback.print_exc()
        # audit nunca pode derrubar request
    finally:
        db.close()


class RequestAuditMiddleware(BaseHTTPMiddleware):
    def __init__(self, app: ASGIApp):
        super().__init__(app)

    async def dispatch(self, request: Request, call_next):
        request_id = request.headers.get("x-request-id") or uuid.uuid4().hex
        t0 = time.perf_counter()

        # segue o jogo
        response = await call_next(request)

        dt_ms = (time.perf_counter() - t0) * 1000.0

        # headers padrão do projeto
        response.headers["x-request-id"] = request_id
        response.headers["x-process-time-ms"] = f"{dt_ms:.2f}"

        # tenta extrair identidade do token (se houver)
        username, role = _extract_claims(request.headers.get("authorization"))

        client_ip = request.client.host if request.client else None
        user_agent = request.headers.get("user-agent")

        # grava em background thread (não trava o event loop)
        try:
            await anyio.to_thread.run_sync(partial(
                _write_audit_row,
                request_id=request_id,
                method=request.method,
                path=request.url.path,
                status_code=response.status_code,
                process_time_ms=dt_ms,
                username=username,
                role=role,
                client_ip=client_ip,
                user_agent=user_agent,
            ))
        except Exception as e:
            import sys, traceback
            print(f"AUDIT_BG_FAIL: {e!r}", file=sys.stderr)
            traceback.print_exc()

        return response


def install_middleware(app) -> None:
    # compat: se o main.py chamar isso, funciona
    app.add_middleware(RequestAuditMiddleware)

# --- Backward-compat ---
# main.py (ou versões antigas) podem importar RequestContextMiddleware.
# Mantemos como alias do middleware atual.
class RequestContextMiddleware(RequestAuditMiddleware):
    pass

